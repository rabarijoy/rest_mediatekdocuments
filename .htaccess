Options +FollowSymLinks
RewriteEngine on
RewriteCond %{HTTP:Authorization} ^(.+)$
RewriteRule ^(.*)$ - [E=HTTP_AUTHORIZATION:%1]
# RewriteBase à adapter selon l'hébergeur :
# - Si le domaine pointe vers le dossier REST lui-même (AwardSpace sous-domaine) : RewriteBase /
# - Si le dossier REST est un sous-dossier de www/ : RewriteBase /rest_mediatekdocuments/
RewriteBase /

# Laisser passer les accès directs au dossier scripts/ (backup_trigger.php)
RewriteRule ^scripts/ - [L]

# Refuser l'accès direct à la racine sans paramètre de route
RewriteCond %{REQUEST_URI} ^/?$
RewriteRule ^ - [R=400,L]

# GET /table
RewriteCond %{REQUEST_METHOD} =GET
RewriteRule ^([a-zA-Z0-9_-]+)$ src/index.php?table=$1 [B,QSA,L]
# GET /table/{id}
RewriteCond %{REQUEST_METHOD} =GET
RewriteRule ^([a-zA-Z0-9_-]+)/([a-zA-Z0-9_-]+)$ src/index.php?table=$1&id=$2 [B,QSA,L]
# GET /table/{champs json}
RewriteCond %{REQUEST_METHOD} =GET
RewriteRule ^([a-zA-Z0-9_-]+)/({.*})$ src/index.php?table=$1&champs=$2 [B,QSA,L]

# POST /table
RewriteCond %{REQUEST_METHOD} =POST
RewriteRule ^([a-zA-Z0-9_-]+)$ src/index.php?table=$1 [B,QSA,L]

# PUT /table
RewriteCond %{REQUEST_METHOD} =PUT
RewriteRule ^([a-zA-Z0-9_-]+)$ src/index.php?table=$1 [B,QSA,L]
# PUT /table/{id}
RewriteCond %{REQUEST_METHOD} =PUT
RewriteRule ^([a-zA-Z0-9_-]+)/([a-zA-Z0-9_-]+)$ src/index.php?table=$1&id=$2 [B,QSA,L]

# DELETE /table
RewriteCond %{REQUEST_METHOD} =DELETE
RewriteRule ^([a-zA-Z0-9_-]+)$ src/index.php?table=$1 [B,QSA,L]
# DELETE /table/{id}
RewriteCond %{REQUEST_METHOD} =DELETE
RewriteRule ^([a-zA-Z0-9_-]+)/([a-zA-Z0-9_-]+)$ src/index.php?table=$1&id=$2 [B,QSA,L]
# DELETE /table/{champs json}
RewriteCond %{REQUEST_METHOD} =DELETE
RewriteRule ^([a-zA-Z0-9_-]+)/({.*})$ src/index.php?table=$1&champs=$2 [B,QSA,L]
