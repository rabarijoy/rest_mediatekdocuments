  "item": [
    {
      "name": "GET /genre",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Common envelope checks",
              "pm.test(\"HTTP status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "let json;",
              "pm.test(\"Response is valid JSON\", function () {",
              "  json = pm.response.json();",
              "  pm.expect(json).to.be.ok;",
              "});",
              "",
              "pm.test(\"Response envelope has code/message/result\", function () {",
              "  if (!json) json = pm.response.json();",
              "  pm.expect(json).to.be.an(\"object\");",
              "  pm.expect(json).to.have.property(\"code\");",
              "  pm.expect(json).to.have.property(\"message\");",
              "  pm.expect(json).to.have.property(\"result\");",
              "});",
              "",
              "pm.test(\"Envelope code is 200\", function () {",
              "  if (!json) json = pm.response.json();",
              "  pm.expect(json.code).to.eql(200);",
              "});",
              "",
              "// Endpoint-specific: /genre GET -> result non empty (array non empty OR string non empty)",
              "pm.test(\"/genre result is non-empty\", function () {",
              "  if (!json) json = pm.response.json();",
              "  const r = json.result;",
              "",
              "  const isNonEmptyArray = Array.isArray(r) && r.length > 0;",
              "  const isNonEmptyString = (typeof r === 'string') && r.trim().length > 0;",
              "",
              "  pm.expect(isNonEmptyArray || isNonEmptyString, \"result should be a non-empty array or non-empty string\").to.be.true;",
              "});",
              ""
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "basic",
          "basic": [
            {
              "key": "username",
              "value": "admin",
              "type": "string"
            },
            {
              "key": "password",
              "value": "adminpwd",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost/rest_mediatekdocuments/genre",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "path": [
            "rest_mediatekdocuments",
            "genre"
          ]
        },
        "description": "Generated from cURL: curl --location --request GET 'http://localhost/rest_mediatekdocuments/genre' --user 'admin:adminpwd'"
      },
      "response": []
    },
