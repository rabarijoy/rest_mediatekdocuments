              "pm.test(\"JSON has expected envelope (code, message, result)\", function () {",
              "  pm.expect(json).to.be.an(\"object\");",
              "  pm.expect(json).to.have.property(\"code\");",
              "  pm.expect(json).to.have.property(\"message\");",
              "  pm.expect(json).to.have.property(\"result\");",
              "});",
              "",
              "pm.test(\"Envelope code == 200\", function () {",
              "  pm.expect(json.code).to.eql(200);",
              "});",
              "",
              "// Endpoint-specific constraint: /utilisateur GET => idService non vide",
              "pm.test(\"/utilisateur result contains idService\", function () {",
              "  const r = json.result;",
              "  if (Array.isArray(r)) {",
              "    pm.expect(r.some(x => x && x.idService), \"at least one element with idService\").to.eql(true);",
              "  } else if (r && typeof r === \"object\") {",
              "    pm.expect(r.idService, \"result.idService\").to.be.ok;",
              "  } else {",
              "    pm.expect.fail(\"Expected result to be an object or an array\");",
              "  }",
              "});",
              ""
            ]
          }
        }
      ],
